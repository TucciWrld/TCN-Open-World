; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=5

[application]

config/name="TCN Open World"
config/version="1.0"
config/description="TCN Open World - A complete Android 3D open-world game developed by Tucci Cyber Nation"
run/main_scene="res://src/scenes/ui/main_menu.tscn"
config/icon="res://assets/logo/tcn_logo.svg"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/handheld_mode=true
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[input]

ui_accept={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 4194309)]}
ui_select={"deadzone": 0.5, "events": [Object(InputEventJoypadButton, "button_index": 3)]}
ui_cancel={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 4194305)]}
ui_focus_next={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 4194320)]}
ui_focus_prev={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 4194319)]}
ui_left={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 65), Object(InputEventJoypadMotion, "axis": 0, "axis_value": -1.0)]}
ui_right={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 68), Object(InputEventJoypadMotion, "axis": 0, "axis_value": 1.0)]}
ui_up={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 87), Object(InputEventJoypadMotion, "axis": 1, "axis_value": -1.0)]}
ui_down={"deadzone": 0.5, "events": [Object(InputEventKey, "keycode": 83), Object(InputEventJoypadMotion, "axis": 1, "axis_value": 1.0)]}

[physics]

3d/physics_engine="GodotPhysics3D"

[rendering]

rendering/anti_aliasing/quality/msaa_3d=2
rendering/textures/vram_compression/import_etc2_astc=true
